' Preview durch <Alt>d

@startuml ER Diagramm

' hide the spot
hide circle

' evtl. Prbleme mit Kraehenfuessen vermeiden
skinparam linetype ortho

entity "Mitglied" {
  * id : integer <<generated>>
  --
  * version: integer
  * vorname : text
  * nachname : text
  * email : text <<unique>>
  * geburtsdatum: date
  * telefonnummer: text
  * geschlecht: Geschlecht
  * mitgliedstatus: Mitgliedstatus
  * interessen: JSON
  * beitritsdatum: date
  * erzeugt: timestamp
  * aktualisiert: timestamp
}

entity "Ausweis" {
  * id : integer <<generated>>
  --
  * ausstellungsdatum : date
  * ablaufdatum : date
  * **mitglied_id**: integer <<FK>>
}

entity "Ausleihe" {
  * id : integer <<generated>>
  --
  * ausleihdatum : date
  * rueckgabedatum : date
  * **mitglied_id**: integer <<FK>>
}

Mitglied ||.left.|| Ausweis
Mitglied ||..o{ Ausleihe

footer (c) Murat Yahsi, Jeton Rama

@enduml
